# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hrms_user:hrms_password_dev@localhost:5432/hrms?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO (File Storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="hrms_minio"
MINIO_SECRET_KEY="hrms_minio_secret"
MINIO_BUCKET="hrms-documents"
MINIO_USE_SSL=false

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-at-least-32-characters-long"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (SMTP) - BASE / default profile ───────────────────────────────────
# For @digitallynext.com sender addresses, use Brevo (smtp-relay.brevo.com) with
# the domain authenticated (SPF/DKIM/DMARC). SMTP_USER/PASS are the Brevo SMTP
# login + generated SMTP key, NOT your account password.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Digitally Next <noreply@digitallynext.com>"

# ─── Email profiles (per use-case) ───────────────────────────────────────────
# A profile inherits HOST/PORT/SECURE/USER/PASS from the base SMTP_* above unless
# overridden with SMTP_<PROFILE>_*. Usually you only set a different FROM.
SMTP_NOTIFICATIONS_FROM="Digitally Next <notification@digitallynext.com>"
# SMTP_HR_FROM="DN HR <hr@digitallynext.com>"

# Logo shown in transactional emails (use a PUBLIC PNG for best client support)
EMAIL_LOGO_URL=""

# ─── Encryption (at-rest secrets, e.g. employee Gmail App Passwords) ─────────
# 32-byte AES-256-GCM key, base64-encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key invalidates every stored Gmail App Password - employees must re-enter.
ENCRYPTION_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="HRMS"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Public Careers API ──────────────────────────────────────────────────────
# Shared secret consumers (e.g. marketing site) send as `X-API-Key` header
# Generate with: openssl rand -hex 32
CAREERS_API_KEY=""

# ─── Groq (AI auto-fill for job postings) ────────────────────────────────────
# Used by the "Generate with AI" button in the job-creation form.
# Sign up at https://console.groq.com/ - free tier is generous.
GROQ_API_KEY=""
